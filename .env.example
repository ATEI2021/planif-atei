# Base de données (SQLite/libSQL en V1)
# En local : rien à renseigner, fichier ./data/planif.db utilisé par défaut.
# En production (Vercel) : renseigner l'URL et le token de la base Turso.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# URL publique de l'app (utilisée pour générer les liens courts SMS)
APP_URL="http://localhost:3000"

# Brevo (SMS + email transactionnel)
BREVO_API_KEY=""
BREVO_SMS_SENDER="ATEI"
BREVO_EMAIL_FROM="ateipro@hotmail.com"
BREVO_EMAIL_TO_VINCENT="ateipro@hotmail.com"

# Auth back-office (Vincent)
AUTH_SECRET=""
BACKOFFICE_EMAIL=""
BACKOFFICE_PASSWORD_HASH=""

# Cron quotidien (rappels J-7/J-2, relance J+5, alerte J+8)
# Genere par Vercel automatiquement si le cron est configure via vercel.json,
# mais doit aussi etre defini ici pour les appels manuels/tests.
CRON_SECRET=""
